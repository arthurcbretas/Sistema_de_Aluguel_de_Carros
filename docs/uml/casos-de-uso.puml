@startuml CasosDeUso
left to right direction
skinparam actorStyle awesome

actor Cliente
actor Agente
actor Empresa
actor Banco
actor Sistema

Empresa --|> Agente
Banco   --|> Agente

rectangle "Sistema de Aluguel de Carros" {

  usecase "UC01\nRealizar Cadastro"             as UC01
  usecase "UC02\nRealizar Login"                as UC02
  usecase "UC03\nCriar Pedido"                  as UC03
  usecase "UC04\nConsultar Pedido"              as UC04
  usecase "UC05\nModificar Pedido"              as UC05
  usecase "UC06\nCancelar Pedido"               as UC06
  usecase "UC07\nGerenciar Rendimentos (max 3)" as UC07
  usecase "UC08\nGerenciar Empregadores (max 3)" as UC08
  usecase "UC09\nAvaliar Pedido"                as UC09
  usecase "UC10\nGerar Contrato"                as UC10
  usecase "UC11\nAssociar Credito"              as UC11
  usecase "UC12\nConsultar Automoveis"          as UC12
  usecase "UC13\nPesquisar Frota (Catálogo)"   as UC13
  usecase "UC14\nGerenciar Frota (CRUD)"       as UC14
}

Cliente --> UC01
Cliente --> UC02
Cliente --> UC03
Cliente --> UC04
Cliente --> UC05
Cliente --> UC06
Cliente --> UC07
Cliente --> UC08
Cliente --> UC12
Cliente --> UC13

Agente  --> UC09
Empresa --> UC14
Banco   --> UC11
Banco   --> UC02
Sistema --> UC10

UC03 ..> UC02 : <<include>>
UC05 ..> UC04 : <<include>>
UC06 ..> UC04 : <<include>>
UC10 ..> UC09 : <<include>>

note right of UC10 : Gerado automaticamente\npos aprovacao
note right of UC07 : Regra: maximo 3\npor cliente
note right of UC13 : Filtragem por marca,\nmodelo e ano com\nimagens dos veículos
note right of UC14 : Cadastro com URL de\nimagem do veículo

@enduml
